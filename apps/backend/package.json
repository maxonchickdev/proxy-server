{
	"name": "@proxy-server/backend",
	"version": "1.0.0",
	"description": "Backend application for Proxy Server",
	"main": "src/main.ts",
	"author": "maxondev",
	"license": "ISC",
	"engines": {
		"node": "22.22.0",
		"npm": "10.9.4"
	},
	"scripts": {
		"build": "npm run build -w @proxy-server/shared && nest build",
		"start": "nest start",
		"prestart:dev": "npm run build -w @proxy-server/shared",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/src/main",
		"compodoc": "npx compodoc -p tsconfig.doc.json -r 3001 -d compodoc --hideGenerator --minimal -s -w",
		"db:generate": "prisma generate",
		"db:migrate:dev": "prisma migrate dev",
		"db:migrate:deploy": "prisma migrate deploy",
		"db:migrate:reset": "prisma migrate reset",
		"db:seed": "prisma db seed",
		"db:push": "prisma db push",
		"db:studio": "prisma studio --browser none",
		"lint:types:check": "tsc -p tsconfig.json",
		"lint:check": "biome lint",
		"lint:fix": "biome lint --write",
		"lint:format:check": "biome format",
		"lint:format:fix": "biome format --write"
	},
	"dependencies": {
		"@nestjs/cli": "^11.0.16",
		"@nestjs/common": "^11.1.17",
		"@nestjs/config": "^4.0.3",
		"@nestjs/core": "^11.1.17",
		"@nestjs/jwt": "^11.0.2",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "^11.1.17",
		"@nestjs/schedule": "^6.1.1",
		"@nestjs/schematics": "^11.0.9",
		"@nestjs/swagger": "^11.2.6",
		"@nestjs/throttler": "^6.5.0",
		"@prisma/adapter-pg": "^7.5.0",
		"@prisma/client": "^7.5.0",
		"@proxy-server/shared": "*",
		"@types/express": "^5.0.6",
		"bcrypt": "^6.0.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"cookie-parser": "^1.4.7",
		"helmet": "^8.1.0",
		"ioredis": "^5.10.1",
		"joi": "^18.0.2",
		"nanoid": "^5.1.7",
		"nodemailer": "^8.0.3",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"prisma": "^7.5.0",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"source-map-support": "^0.5.21"
	},
	"devDependencies": {
		"@types/bcrypt": "^6.0.0",
		"@types/cookie-parser": "^1.4.10",
		"@types/node": "^25.5.0",
		"@types/nodemailer": "^8.0.0",
		"@types/passport-jwt": "^4.0.1",
		"tsconfig-paths": "^4.2.0"
	}
}
