POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/proxy_server?schema=public
# Prisma CLI (prisma.config.ts) accepts DATABASE_URL or POSTGRES_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/proxy_server?schema=public

REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASES=16

RI_PORT=5540
RI_DISABLE_ENCRYPTION=true

POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=proxy_server

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

APP_PORT=3000
APP_REQUEST_TIMEOUT=30000
NODE_ENV=development

CORS_ORIGIN=http://localhost:5173

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Proxy Server <noreply@localhost>
SMTP_LOG_OTP_ON_FAILURE=false

SWAGGER_PATH=docs
SWAGGER_NAME=Proxy Server API
SWAGGER_DESCR=API documentation for the Proxy Server backend
SWAGGER_SITE_TITLE=Proxy Server API Docs

PROXY_BASE_DOMAIN=lvh.me
