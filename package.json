{
	"name": "proxy-server",
	"version": "1.0.0",
	"description": "Proxy Server",
	"scripts": {
		"docker:local:up": "docker compose --env-file apps/backend/.env -f docker-compose.local.yml up -d --no-color --timestamps --wait --wait-timeout 20",
		"docker:local:down": "docker compose --env-file apps/backend/.env -f docker-compose.local.yml down -v",
		"docker:local:start": "docker compose --env-file apps/backend/.env -f docker-compose.local.yml start",
		"docker:local:stop": "docker compose --env-file apps/backend/.env -f docker-compose.local.yml stop -t 10",
		"docker:prod:up": "docker compose --env-file apps/backend/.env.prod -f docker-compose.prod.yml up -d --no-color --timestamps --wait --wait-timeout 20",
		"docker:prod:down": "docker compose --env-file apps/backend/.env.prod -f docker-compose.prod.yml down -v",
		"docker:prod:start": "docker compose --env-file apps/backend/.env.prod -f docker-compose.prod.yml start",
		"docker:prod:stop": "docker compose --env-file apps/backend/.env.prod -f docker-compose.prod.yml stop -t 10",
		"lint:check": "biome lint",
		"lint:fix": "biome lint --write",
		"lint:format:check": "biome format",
		"lint:format:fix": "biome format --write",
		"lint:clean:check": "knip",
		"lint:fs:check": "ls-lint",
		"hooks:init": "simple-git-hooks",
		"hooks:precommit": "lint-staged",
		"hooks:prepush": "concurrently 'npm run build -w apps/backend' 'npm run build -w apps/web'"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/maxonchickdev/proxy-server.git"
	},
	"keywords": [],
	"author": "maxondev",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/maxonchickdev/proxy-server/issues"
	},
	"homepage": "https://github.com/maxonchickdev/proxy-server#readme",
	"workspaces": [
		"apps/web",
		"apps/backend",
		"libs/shared"
	],
	"engines": {
		"node": "22.22.0",
		"npm": "10.9.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@ls-lint/ls-lint": "^2.3.1",
		"@types/node": "^25.5.0",
		"concurrently": "^9.2.1",
		"knip": "^6.3.1",
		"lint-staged": "^16.4.0",
		"simple-git-hooks": "^2.13.1",
		"typescript": "^6.0.2"
	}
}
