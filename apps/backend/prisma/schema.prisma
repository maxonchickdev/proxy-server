// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String  @map("password_hash")
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")

  endpoints           Endpoint[]
  notificationChannels NotificationChannel[]
  alertRules          AlertRule[]

  @@map("users")
}

model Endpoint {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  slug      String   @unique
  targetUrl String   @map("target_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestLogs RequestLog[]
  alertRules  AlertRule[]

  @@map("endpoints")
}

model RequestLog {
  id              String   @id @default(uuid())
  endpointId      String   @map("endpoint_id")
  method          String
  path            String
  queryParams     String?  @map("query_params")
  requestHeaders  Json?    @map("request_headers")
  requestBody     String?  @map("request_body")
  responseStatus  Int?     @map("response_status")
  responseHeaders Json?    @map("response_headers")
  responseBody    String?  @map("response_body")
  durationMs      Int?     @map("duration_ms")
  clientIp        String?  @map("client_ip")
  createdAt       DateTime @default(now()) @map("created_at")

  endpoint Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, createdAt])
  @@index([createdAt])
  @@map("request_logs")
}

model NotificationChannel {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   // TELEGRAM | SLACK
  config    Json     // { botToken, chatId } or { webhookUrl }
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertRules AlertRule[]

  @@map("notification_channels")
}

model AlertRule {
  id         String   @id @default(uuid())
  endpointId String   @map("endpoint_id")
  userId     String   @map("user_id")
  channelId String   @map("channel_id")
  condition  String   // e.g. "status >= 500", "latency > 2000"
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  endpoint   Endpoint           @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel    NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("alert_rules")
}
