# Database (PostgreSQL) - used by Prisma
# When using proxy-server Docker: postgres:postgres, db: proxy_server
# When using existing Postgres: adjust USER/PASSWORD/DB as needed
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/proxy_server?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASES=16
RI_PORT=5540
RI_DISABLE_ENCRYPTION=true

# PostgreSQL (for Docker Compose) - must match DATABASE_URL
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=proxy_server

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# App
PORT=3000
NODE_ENV=development

# Proxy (for subdomain routing)
PROXY_BASE_DOMAIN=lvh.me
