{
	"$schema": "https://json.schemastore.org/nest-cli",
	"collection": "@nestjs/schematics",
	"sourceRoot": "src",
	"compilerOptions": {
		"builder": "tsc",
		"deleteOutDir": true,
		"tsConfigPath": "tsconfig.build.json",
		"assets": [
			{
				"include": "proxy/proto/*.proto",
				"outDir": "dist",
				"watchAssets": true
			}
		]
	},
	"plugins": [
		{
			"name": "@nestjs/swagger",
			"options": {
				"classValidatorShim": true,
				"introspectComments": true
			}
		}
	]
}
